# Example nginx site for api.selorg.com
# Dashboard login needs /api/v1/admin/* — not only /api/v1/customer/*
# CORS headers are set by the Node app; do not strip them here.

upstream selorg_backend {
    server 127.0.0.1:3333;
    keepalive 32;
}

server {
    listen 80;
    server_name api.selorg.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name api.selorg.com;

    # ssl_certificate /etc/letsencrypt/live/api.selorg.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/api.selorg.com/privkey.pem;

    client_max_body_size 20m;

    location /health {
        proxy_pass http://selorg_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # All REST APIs (admin, darkstore, customer, logistics, …)
    location /api/ {
        proxy_pass http://selorg_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Socket.IO (dashboard / HHD / rider — adjust paths to match your deployment)
    location /socket.io/ {
        proxy_pass http://selorg_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /hhd-socket.io/ {
        proxy_pass http://selorg_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }

    location /ws {
        proxy_pass http://selorg_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }
}
