############################
# Selorg Backend (Production)
############################

# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3333

# Database
# Prefer mongodb+srv://... for Atlas, or mongodb://... for self-hosted.
MONGO_URI=

# Auth
# Must be >= 32 chars (validateEnv enforces strength).
JWT_SECRET=
# Customer app can use a separate secret; if empty, backend falls back to JWT_SECRET.
CUSTOMER_JWT_SECRET=

# CORS (Dashboard/admin web origins; any https://*.selorg.com is also allowed in production)
# Comma-separated extra origins beyond the built-in defaults:
ALLOWED_ORIGINS=https://dashboard.selorg.com,https://www.dashboard.selorg.com

# Optional flags
ENABLE_SWAGGER=false
ENABLE_METRICS=false

########################################
# Worldline / Paynimo (Production / Live)
########################################
# Paynimo official docs say `returnUrl` is mandatory and is where the response is posted.
# Use your public API host here (must be reachable by Worldline).
WORLDLINE_ENABLED=true

# Use ONE consistent merchant id across both vars (service prefers WORLDLINE_MERCHANT_ID when set).
WORLDLINE_MERCHANT_ID=
WORLDLINE_MERCHANT_CODE=

# Scheme code provided by Worldline (often "FIRST" for default mapping).
WORLDLINE_SCHEME_CODE=FIRST

# Hashing salt provided by Worldline for token + response verification.
WORLDLINE_SALT=

# Must point to the backend route that accepts GET/POST without auth:
# `src/customer-backend/routes/paymentsRoutes.js` → `/api/v1/customer/payments/worldline/return`
WORLDLINE_RETURN_URL=https://api.selorg.com/api/v1/customer/payments/worldline/return

# sh2 -> SHA-512 (default); sh1 -> SHA-256. Keep aligned with your Worldline kit config.
WORLDLINE_HASH_ALGO=sh2

# Sandbox kits often cap to ₹1–₹10. For live, set to your merchant’s accepted range.
WORLDLINE_MIN_AMOUNT_INR=1
WORLDLINE_MAX_AMOUNT_INR=100000

# Reconciliation: pending -> unknown after N minutes
WORLDLINE_RECONCILE_STALE_MINUTES=15

# Standalone initiate is disabled by default in production unless explicitly enabled.
PAYMENT_STANDALONE_INITIATE=false

# Optional AES material (used only if you explicitly enable a flow needing it)
# PAYMENT_AES_KEY=   # 32 bytes (base64/hex/utf8) for AES-256 (or 16 bytes for AES-128)
# PAYMENT_AES_IV=    # 16 bytes (base64/hex/utf8)

############################
# Q-Commerce logistics (B2B bulk)
############################
# LOGISTICS_ENABLED=true
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
# LOGISTICS_EXCHANGE=logistics.events
# LOGISTICS_DLQ_EXCHANGE=logistics.events.dlq
# Redis (optional locally; set REDIS_URL or REDIS_ENABLED=true when Redis is running)
# REDIS_URL=redis://localhost:6379
# REDIS_ENABLED=true
# DISABLE_REDIS=true
# PORTER_API_BASE_URL=https://api.porter.in
# PORTER_API_KEY=
# PORTER_HMAC_SECRET=
# LOGISTICS_CRED_ENCRYPTION_KEY=
# LOGISTICS_FAILOVER_TIMEOUT_MS=15000
