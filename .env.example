### Server
PORT=5001
NODE_ENV=development
API_VERSION=v1

# Customer order cancellations per user per calendar day (optional).
# If unset, defaults to 1000. Set lower in production if you need a stricter cap.
CUSTOMER_MAX_CANCELLATIONS_PER_DAY=1000

### Auth
# Must be at least 32 characters long (generate with: openssl rand -base64 32)
JWT_SECRET=
JWT_EXPIRES_IN=24h

### Database
# Mongo connection string (choose one)
MONGO_URI=
MONGODB_URI=

### Vendor hub (tenant scoping)
# Default procurement hub key used by vendor dashboard when a user record has no hubKey.
DASHBOARD_HUB_KEY=chennai-hub

### Compliance / Metrics (optional but recommended)
ENABLE_SWAGGER=false
ENABLE_METRICS=false

### Rate limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

### Cache TTLs (optional overrides; defaults exist in code)
CACHE_TTL_DEFAULT=60
CACHE_TTL_VENDOR=60

# If you want to disable caching entirely:
# DISABLE_CACHE=false

### Worldline / Paynimo (Customer app payments)
# Enable the integration only when all values are configured.
WORLDLINE_ENABLED=false

# Provided by Worldline for the merchant in each environment
WORLDLINE_MERCHANT_ID=

# Scheme code (maps to itemId in Paynimo request). Email shows FIRST.
WORLDLINE_SCHEME_CODE=FIRST

# Hash salt used at end of the pipe-separated token string + response hash verification.
# Worldline/Paynimo: use the merchant "Encryption Key" value as WORLDLINE_SALT (trim whitespace).
WORLDLINE_SALT=

# sh2 = SHA-512 (Paynimo AndroidSH2 default). sh1 = SHA-256 / AndroidSH1. Overrides optional client algo.
# WORLDLINE_HASH_ALGO=sh2

# Optional (only if your kit requires encryption of fields)
WORLDLINE_ENC_KEY=
WORLDLINE_ENC_IV=

# Return URL expected by Worldline kit (often a hosted merchant response page).
WORLDLINE_RETURN_URL=

# Must match Worldline kit limits (sandbox is usually ₹1–₹10 on order total, incl. delivery/fees). Raise for production.
WORLDLINE_MIN_AMOUNT_INR=1
WORLDLINE_MAX_AMOUNT_INR=10

### Customer OTP / SMS
# Real SMS to handsets: leave OTP_DEV_MODE unset (or OTP_DEV_MODE=0). OTP_DEV_MODE=1 disables all SMS providers.
#
# Primary gateway is src/config.json → smsvendor (Spear UC). If the API returns "Insufficient SMS Credits",
# recharge that Spear account OR add MSG91 (or Fast2SMS / Twilio) below — the backend tries Spear first, then
# these env vars override/augment config.json (see msg91AuthKey in config.json).
#
# Set OTP_DEV_MODE=1 only for local testing without SMS (OTP printed in server logs). Never on production.
# OTP_DEV_MODE=1
#
# India DLT: smsMessageTemplate in config.json must match your registered template; MSG91 needs otp_template_id.
#
# MSG91 (sendotp API): https://api.msg91.com/api/sendotp.php
# MSG91_AUTH_KEY=
# MSG91_SENDER=
# MSG91_TEMPLATE_ID=
#
# Fast2SMS (bulkV2)
# FAST2SMS_API_KEY=
# FAST2SMS_ROUTE=q
#
# Twilio (works globally; TWILIO_FROM is accepted as well as TWILIO_PHONE_NUMBER)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_FROM=
#
# Optional: comma-separated 10-digit numbers that skip SMS (testing only)
# OTP_BYPASS_NUMBERS=

