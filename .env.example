### Server
PORT=5001
NODE_ENV=development
API_VERSION=v1

### Auth
# Must be at least 32 characters long (generate with: openssl rand -base64 32)
JWT_SECRET=
JWT_EXPIRES_IN=24h

### Database
# Mongo connection string (choose one)
MONGO_URI=
MONGODB_URI=

### Vendor hub (tenant scoping)
# Default procurement hub key used by vendor dashboard when a user record has no hubKey.
DASHBOARD_HUB_KEY=chennai-hub

### Compliance / Metrics (optional but recommended)
ENABLE_SWAGGER=false
ENABLE_METRICS=false

### Rate limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

### Cache TTLs (optional overrides; defaults exist in code)
CACHE_TTL_DEFAULT=60
CACHE_TTL_VENDOR=60

# If you want to disable caching entirely:
# DISABLE_CACHE=false

### Worldline / Paynimo (Customer app payments)
# Enable the integration only when all values are configured.
WORLDLINE_ENABLED=false

# Provided by Worldline for the merchant in each environment
WORLDLINE_MERCHANT_ID=

# Scheme code (maps to itemId in Paynimo request). Email shows FIRST.
WORLDLINE_SCHEME_CODE=FIRST

# Hash salt/secret used for token generation + response hash verification.
# IMPORTANT: This is NOT the "Encryption Key" from the email unless Worldline confirms it.
WORLDLINE_SALT=

# Optional (only if your kit requires encryption of fields)
WORLDLINE_ENC_KEY=
WORLDLINE_ENC_IV=

# Return URL expected by Worldline kit (often a hosted merchant response page).
WORLDLINE_RETURN_URL=

# Test environment amount limits (email: 1..10 INR). Override in prod.
WORLDLINE_MIN_AMOUNT_INR=1
WORLDLINE_MAX_AMOUNT_INR=10

